rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'super_admin' ||
        request.auth.token.email == 'saiganeshkrovvidi.092005@gmail.com'
      );
    }

    function isOrgVerifier(orgId) {
      return isAuthenticated() && 
             getUserData().role == 'organization' && 
             getUserData().organizationId == orgId;
    }

    function getRequestData(requestId) {
      return firestore.get(/databases/(default)/documents/verificationRequests/$(requestId)).data;
    }

    // Match files under verificationRequests/{requestId}/{fileName}
    match /verificationRequests/{requestId}/{fileName} {
      // Users can upload files if they are authenticated and the file does not already exist (prevents overwriting)
      allow create: if isAuthenticated() && resource == null;

      // Access (Read/Delete) is restricted based on Firestore request ownership and verification assignment
      allow read: if isAuthenticated() && (
        getRequestData(requestId).ownerId == request.auth.uid ||
        isOrgVerifier(getRequestData(requestId).organization.id) ||
        isSuperAdmin()
      );
      
      allow delete: if isSuperAdmin();
    }
  }
}
